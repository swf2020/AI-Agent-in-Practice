{
  "skill_name": "ai-agent-interview-collector",
  "evals": [
    {
      "id": 1,
      "prompt": "AI Agent 工程师社招面试题集，更新一下",
      "expected_output": "生成一个 Markdown 文件，包含 Module 1-8 分类题目、来源标注、采集日期，以及近期高频题汇总。",
      "assertions": [
        {
          "text": "输出文件存在且路径含日期（如 ai_agent_interview_questions_20250502.md）",
          "type": "file_exists"
        },
        {
          "text": "文件包含 8 个 Module 章节标题（Module 1 到 Module 8）",
          "type": "content_contains_all",
          "values": ["Module 1", "Module 2", "Module 3", "Module 4", "Module 5", "Module 6", "Module 7", "Module 8"]
        },
        {
          "text": "至少包含 10 道题目（行以 '- [来源:' 开头）",
          "type": "min_count",
          "pattern": "^- \\[来源:",
          "min": 10
        },
        {
          "text": "包含'近期高频题'或'高频'章节",
          "type": "content_contains",
          "value": "高频"
        },
        {
          "text": "每道题都有来源标注（格式 [来源:XXX]）",
          "type": "content_contains",
          "value": "[来源:"
        },
        {
          "text": "头部包含采集日期信息",
          "type": "content_contains",
          "value": "采集日期"
        }
      ]
    },
    {
      "id": 2,
      "prompt": "我下周要参加字节跳动 AI 工程师二面，帮我刷新 AI Agent 面试题，重点关注 RAG 和 Multi-Agent 这两块",
      "expected_output": "生成面试题集，Module 2（RAG）和 Module 5（多 Agent）题目数量相对较多，文件包含来源标注和高频题汇总。",
      "assertions": [
        {
          "text": "输出 Markdown 文件存在",
          "type": "file_exists"
        },
        {
          "text": "Module 2 RAG 类题目不少于 3 道",
          "type": "min_count_in_section",
          "section": "Module 2",
          "min": 3
        },
        {
          "text": "Module 5 多 Agent 类题目不少于 2 道",
          "type": "min_count_in_section",
          "section": "Module 5",
          "min": 2
        },
        {
          "text": "执行汇报中提到了搜索覆盖的平台",
          "type": "response_contains_any",
          "values": ["牛客", "小红书", "脉脉", "B站"]
        }
      ]
    },
    {
      "id": 3,
      "prompt": "跑一次面试题采集",
      "expected_output": "生成完整题集文件，并在对话中汇报：搜索成功/失败的平台、新增题目数、输出文件路径、Top 5 高频题。",
      "assertions": [
        {
          "text": "对话回复中包含输出文件路径",
          "type": "response_contains",
          "value": "ai_agent_interview_questions_"
        },
        {
          "text": "对话回复中汇报了题目数量",
          "type": "response_contains_any",
          "values": ["题", "道题", "新增"]
        },
        {
          "text": "对话回复中包含高频题 Top 信息",
          "type": "response_contains_any",
          "values": ["高频", "Top", "出现"]
        },
        {
          "text": "输出文件包含至少 5 个 Module 的内容",
          "type": "min_section_count",
          "pattern": "## 🎯 Module",
          "min": 5
        }
      ]
    }
  ]
}
